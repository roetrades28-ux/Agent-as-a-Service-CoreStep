# Supabase — same project as main backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend email provider
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
NOTIFICATIONS_FROM_EMAIL=ralle@corestep.app
NOTIFICATIONS_FROM_NAME=CoreStep TradingLab

# Frontend URL (used in email CTAs)
FRONTEND_URL=https://corestep.app

# Google Gemini — dual key (free primary, paid fallback)
Default_Gemini_API_KEY=your-free-gemini-key
GEMINI_API_KEY=your-paid-gemini-key

# Internal API key — same as main backend INTERNAL_API_KEY
# Render cron jobs send this header to authenticate
INTERNAL_API_KEY=your-internal-key

PORT=4001
NODE_ENV=development
